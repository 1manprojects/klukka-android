<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Klukka" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/glacier</item>
        <item name="colorOnPrimary">@color/glacier_deep</item>
        <item name="colorPrimaryContainer">@color/glacier_mist</item>
        <item name="colorOnPrimaryContainer">@color/glacier_deep</item>
        <item name="colorSecondary">@color/glacier_deep</item>
        <item name="colorOnSecondary">@color/glacier_mist</item>
        <item name="colorSecondaryContainer">@color/glacier_deep</item>
        <item name="colorOnSecondaryContainer">@color/glacier_mist</item>
        <item name="colorTertiary">@color/glacier_mist</item>
        <item name="colorOnTertiary">@color/glacier_deep</item>
    </style>

    <style name="Theme.Klukka" parent="Base.Theme.Klukka" />

    <style name="Widget.Klukka.Button.Action" parent="Widget.Material3.Button">
        <item name="backgroundTint">?attr/colorPrimaryContainer</item>
        <item name="android:textColor">?attr/colorOnPrimaryContainer</item>
        <item name="iconTint">?attr/colorOnPrimaryContainer</item>
        <item name="strokeWidth">2dp</item>
        <item name="strokeColor">?attr/colorOnPrimaryContainer</item>
        <item name="android:elevation">8dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>
</resources>
